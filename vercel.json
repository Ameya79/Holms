{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/chat",
      "dest": "api/index.py"
    },
    {
      "src": "/upload",
      "dest": "api/index.py"
    },
    {
      "src": "/documents/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/documents",
      "dest": "api/index.py"
    },
    {
      "src": "/settings/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/settings",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
